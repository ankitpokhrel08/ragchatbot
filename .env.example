# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Folder containing your .md, .txt, or .pdf docs
ragchatbot_DOCS=./docs

# Where vectors are stored (auto-managed, don't touch)
ragchatbot_DB=./chroma_db

# LLM to use: gemini or ollama
ragchatbot_LLM=gemini

# Set to 0 on first run so embedding model can download (~80MB)
# Set back to 1 after first run
HF_HUB_OFFLINE=1

# Required only if using OpenAI — get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional — if set, all /ask requests must include X-API-Key header
RAGCHATBOT_API_KEY=your-secret-key-here